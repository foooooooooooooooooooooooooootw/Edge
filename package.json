{
  "name": "edge-fileshare",
  "version": "1.35.0",
  "description": "Edge \u2014 P2P file sharing",
  "main": "main.js",
  "author": "foooooooooooooooooooooooooootw",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "keywords": [
    "electron",
    "file-sharing",
    "p2p"
  ],
  "build": {
    "appId": "com.edge.fileshare",
    "productName": "Edge",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "network-manager.js",
      "wan-manager.js",
      "index.html",
      "styles.css",
      "renderer.js",
      "package.json",
      "node_modules/**/*"
    ],
    "compression": "normal",
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network"
    }
  },
  "devDependencies": {
    "electron": "28.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "dgram": "^1.0.1",
    "webtorrent": "1.9.7"
  }
}