{
  "name": "edge-fileshare",
  "version": "1.53.0",
  "description": "Edge \u2014 P2P file sharing",
  "main": "main.js",
  "author": {
    "name": "foooooooooooooooooooooooooootw",
    "email": "foooooooooooooooooooooooooootw@gmail.com"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "keywords": [
    "electron",
    "file-sharing",
    "p2p"
  ],
  "build": {
    "appId": "com.edge.fileshare",
    "productName": "Edge",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "network-manager.js",
      "wan-manager.js",
      "index.html",
      "styles.css",
      "renderer.js",
      "package.json",
      "node_modules/**/*",
      "upnp-client.js",
      "upnp-transfer.js",
      "cert-gen.js",
      "emoji-data.js"
    ],
    "compression": "normal",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network"
    }
  },
  "devDependencies": {
    "electron": "28.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "dgram": "^1.0.1",
    "webtorrent": "1.9.7"
  }
}